@{
    ViewData["Title"] = "About";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="container-fluid px-4 text-center">
        <h2 class="fw-800 text-white mb-2">About ResumeAI</h2>
        <p class="text-white-50">AI-Powered Resume Analyzer & Interview Preparation System</p>
    </div>
</div>

<div class="container py-5">
    <!-- Mission -->
    <div class="row justify-content-center mb-5">
        <div class="col-lg-8 text-center">
            <span class="skill-badge mb-3">🎓 University Project</span>
            <h3 class="fw-700 mb-3">Our Mission</h3>
            <p class="text-muted" style="font-size:1.05rem;line-height:1.8;">
                ResumeAI is a web engineering semester project that demonstrates a full-stack ASP.NET Core MVC application
                with AI-powered resume analysis. We help job seekers understand their resume's strengths and weaknesses,
                improve ATS compatibility, and prepare for technical interviews.
            </p>
        </div>
    </div>

    <!-- Tech Stack -->
    <div class="card mb-5">
        <div class="card-body p-5">
            <h4 class="fw-700 text-center mb-4">Technology Stack</h4>
            <div class="row g-4">
                @{
                    var stack = new[] {
                        ("fab fa-microsoft","ASP.NET Core 8","primary","Backend framework with MVC pattern"),
                        ("fas fa-database","SQL Server","success","Relational database with EF Core"),
                        ("fab fa-js","JavaScript + Chart.js","warning","Frontend interactivity & charts"),
                        ("fas fa-paint-brush","Bootstrap 5","info","Responsive UI components"),
                        ("fas fa-lock","ASP.NET Identity","secondary","Authentication & role management"),
                        ("fas fa-file-pdf","iText7","danger","PDF report generation")
                    };
                }
                @foreach (var (icon, name, color, desc) in stack)
                {
                    <div class="col-md-4">
                        <div class="d-flex gap-3 p-3 rounded-xl" style="background:var(--bg);">
                            <div style="width:44px;height:44px;border-radius:10px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <i class="@icon text-@color"></i>
                            </div>
                            <div>
                                <div class="fw-600">@name</div>
                                <div class="small text-muted">@desc</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Modules -->
    <h4 class="fw-700 text-center mb-4">Project Modules</h4>
    <div class="row g-3 mb-5">
        @{
            var modules = new[] {
                ("Authentication System","fas fa-user-shield","Role-based auth with register, login, forgot password","success"),
                ("Resume Upload & Parsing","fas fa-upload","PDF/DOCX upload with drag-drop, text extraction, skill detection","primary"),
                ("Analysis Engine","fas fa-brain","Resume scoring, ATS compatibility, AI suggestions","secondary"),
                ("Job Description Matching","fas fa-briefcase","Skill comparison, gap analysis, compatibility scoring","warning"),
                ("Interview Preparation","fas fa-microphone","Skill-based questions at 3 difficulty levels","info"),
                ("Analytics Dashboard","fas fa-chart-pie","Charts, trends, skill frequency visualization","success"),
                ("Admin Panel","fas fa-shield-alt","User management, system analytics, content moderation","danger"),
                ("PDF Report Generation","fas fa-file-pdf","Professional downloadable analysis reports","primary"),
                ("Resume History","fas fa-history","Track uploads, compare scores, delete resumes","secondary")
            };
        }
        @foreach (var (name, icon, desc, color) in modules)
        {
            <div class="col-md-4">
                <div class="card card-hover h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="@icon text-@color"></i>
                            <span class="fw-600 small">@name</span>
                        </div>
                        <p class="text-muted mb-0" style="font-size:.82rem;">@desc</p>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Database Schema summary -->
    <div class="card">
        <div class="card-body p-5">
            <h4 class="fw-700 text-center mb-4">Database Design</h4>
            <div class="row g-3 justify-content-center">
                @foreach (var tbl in new[] { "Users","Resumes","Skills","ResumeSkills","JobDescriptions","AnalysisResults","InterviewQuestions","Reports" })
                {
                    <div class="col-auto">
                        <div class="px-4 py-2 rounded-xl fw-600 small" style="background:var(--primary-light);color:var(--primary);border:1px solid rgba(99,102,241,.2);">
                            <i class="fas fa-table me-1"></i>@tbl
                        </div>
                    </div>
                }
            </div>
            <p class="text-muted text-center mt-3 mb-0 small">8 relational tables with proper PKs, FKs, and normalization. Managed via Entity Framework Core migrations.</p>
        </div>
    </div>
</div>
