@{
    ViewData["Title"] = "Features";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="container-fluid px-4 text-center">
        <h2 class="fw-800 text-white mb-2">Platform Features</h2>
        <p class="text-white-50 mb-0">Everything you need to land your dream job</p>
    </div>
</div>

<div class="container py-5">
    <!-- Feature Sections -->
    @{
        var featureSections = new[] {
            new { Icon="fas fa-upload", Title="Smart Resume Upload", Color="primary",
                Points=new[]{"Drag-and-drop PDF & DOCX upload","Instant text extraction","File validation & duplicate detection","Secure encrypted storage"}},
            new { Icon="fas fa-brain", Title="AI-Powered Analysis", Color="secondary",
                Points=new[]{"Extracts name, email, phone automatically","Detects 500+ technical & soft skills","Calculates quality score (0-100)","ATS compatibility rating"}},
            new { Icon="fas fa-briefcase", Title="Job Description Matching", Color="success",
                Points=new[]{"Paste any job description","Instant compatibility percentage","Matched vs missing skills breakdown","Personalized improvement tips"}},
            new { Icon="fas fa-microphone", Title="Interview Preparation", Color="warning",
                Points=new[]{"Skill-based question generation","Beginner / Intermediate / Advanced levels","50+ skill categories covered","Practice tips with each question"}},
            new { Icon="fas fa-chart-pie", Title="Analytics Dashboard", Color="info",
                Points=new[]{"Score trend over time","Skill frequency analysis","Category distribution charts","ATS compatibility tracking"}},
            new { Icon="fas fa-file-pdf", Title="PDF Report Generation", Color="danger",
                Points=new[]{"Professional downloadable reports","Resume score & ATS breakdown","Skills & recommendations included","Interview questions included"}}
        };
    }

    @for (int idx = 0; idx < featureSections.Length; idx++)
    {
        var f = featureSections[idx];
        bool reversed = idx % 2 == 1;
        <div class="row align-items-center g-5 mb-6" style="margin-bottom:5rem;">
            <div class="@(reversed ? "col-lg-6 order-lg-2" : "col-lg-6")">
                <div class="feature-icon" style="background:rgba(var(--@f.Color),0.1);color:var(--@f.Color);width:64px;height:64px;border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin-bottom:1.5rem;background:var(--@f.Color == "primary" ? "primary-light" : $"{f.Color}-subtle");">
                    <i class="@f.Icon" style="color:var(--@f.Color);"></i>
                </div>
                <h3 class="fw-700 mb-3">@f.Title</h3>
                <div class="d-flex flex-column gap-3">
                    @foreach (var p in f.Points)
                    {
                        <div class="d-flex align-items-center gap-3">
                            <div style="width:28px;height:28px;border-radius:8px;background:rgba(16,185,129,.12);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <i class="fas fa-check text-success" style="font-size:.75rem;"></i>
                            </div>
                            <span class="text-muted">@p</span>
                        </div>
                    }
                </div>
                <div class="mt-4">
                    <a asp-controller="Account" asp-action="Register" class="btn btn-primary me-2">Get Started</a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">Sign In</a>
                </div>
            </div>
            <div class="@(reversed ? "col-lg-6 order-lg-1" : "col-lg-6")">
                <div class="p-5 rounded-2xl text-center" style="background:linear-gradient(135deg,rgba(99,102,241,.06),rgba(139,92,246,.06));border:2px dashed var(--border);">
                    <i class="@f.Icon" style="font-size:5rem;color:var(--primary);opacity:.4;"></i>
                    <div class="mt-3 fw-600 text-muted">@f.Title</div>
                </div>
            </div>
        </div>
    }
</div>

<!-- CTA -->
<div style="background:linear-gradient(135deg,var(--primary),var(--secondary));padding:4rem 0;text-align:center;">
    <h2 style="color:#fff;font-weight:700;margin-bottom:1rem;">Ready to get started?</h2>
    <p style="color:rgba(255,255,255,.8);margin-bottom:2rem;">Create your free account and analyze your resume today.</p>
    <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg px-5 fw-600">
        <i class="fas fa-rocket me-2 text-primary"></i>Start Free
    </a>
</div>
