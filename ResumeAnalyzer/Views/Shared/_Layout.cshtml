<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")AI Resume Analyzer</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <!-- Animate.css -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- ── Navbar ──────────────────────────────────────────────────────────────── -->
<nav class="navbar navbar-expand-lg navbar-glass sticky-top">
    <div class="container-fluid px-4">
        <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
            <div class="brand-icon">
                <i class="fas fa-brain"></i>
            </div>
            <span class="brand-text">ResumeAI</span>
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                           asp-controller="Dashboard" asp-action="Index">
                            <i class="fas fa-tachometer-alt me-1"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Resume" && ViewContext.RouteData.Values["action"]?.ToString() == "Upload" ? "active" : "")"
                           asp-controller="Resume" asp-action="Upload">
                            <i class="fas fa-upload me-1"></i>Upload Resume
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "JobMatch" ? "active" : "")"
                           asp-controller="Resume" asp-action="JobMatch">
                            <i class="fas fa-briefcase me-1"></i>Job Match
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "History" ? "active" : "")"
                           asp-controller="Resume" asp-action="History">
                            <i class="fas fa-history me-1"></i>History
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-warning @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")"
                               asp-controller="Admin" asp-action="Index">
                                <i class="fas fa-shield-alt me-1"></i>Admin
                            </a>
                        </li>
                    }
                }
                else
                {
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Features">Features</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">About</a></li>
                }
            </ul>

            <div class="navbar-actions d-flex align-items-center gap-2">
                <!-- Dark mode toggle -->
                <button class="btn btn-icon" id="themeToggle" title="Toggle Dark Mode">
                    <i class="fas fa-moon" id="themeIcon"></i>
                </button>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="dropdown">
                        <button class="btn btn-user dropdown-toggle" data-bs-toggle="dropdown">
                            <div class="avatar-circle">
                                <i class="fas fa-user"></i>
                            </div>
                            <span class="d-none d-md-inline">@User.Identity.Name?.Split('@')[0]</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-lg">
                            <li><h6 class="dropdown-header">@User.Identity.Name</h6></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword"><i class="fas fa-key me-2"></i>Change Password</a></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="fas fa-sign-out-alt me-2"></i>Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-sm">Login</a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm">Get Started</a>
                }
            </div>
        </div>
    </div>
</nav>

<!-- ── Alerts ──────────────────────────────────────────────────────────────── -->
@if (TempData["Success"] != null)
{
    <div class="alert-float animate__animated animate__slideInRight">
        <div class="alert alert-success alert-dismissible shadow" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}
@if (TempData["Info"] != null)
{
    <div class="alert-float animate__animated animate__slideInRight">
        <div class="alert alert-info alert-dismissible shadow" role="alert">
            <i class="fas fa-info-circle me-2"></i> @TempData["Info"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-float animate__animated animate__slideInRight">
        <div class="alert alert-danger alert-dismissible shadow" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}

<!-- ── Main Content ─────────────────────────────────────────────────────────── -->
<main class="main-content">
    @RenderBody()
</main>

<!-- ── Footer ──────────────────────────────────────────────────────────────── -->
<footer class="site-footer mt-auto py-4">
    <div class="container-fluid px-4">
        <div class="row align-items-center">
            <div class="col-md-6">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <div class="brand-icon brand-icon-sm"><i class="fas fa-brain"></i></div>
                    <span class="fw-600">ResumeAI</span>
                </div>
                <small class="text-muted">AI-Powered Resume Analyzer &amp; Interview Prep Platform</small>
            </div>
            <div class="col-md-6 text-md-end mt-3 mt-md-0">
                <small class="text-muted d-block mb-2">
                    &copy; @DateTime.Now.Year ResumeAI — University Web Engineering Project
                </small>
                <div class="footer-links">
                    <a asp-controller="Help" asp-action="Index" class="text-muted me-3 footer-link" title="Help & Support">
                        <i class="fas fa-question-circle me-1"></i>Help
                    </a>
                    <a href="mailto:aafiaazhar0@gmail.com" class="text-muted footer-link" title="Email Us">
                        <i class="fas fa-envelope me-1"></i>Contact
                    </a>
                </div>
            </div>
        </div>
    </div>
</footer>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
