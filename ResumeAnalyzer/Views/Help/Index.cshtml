@{
    ViewData["Title"] = "Help & Support";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="container-fluid px-4">
        <h4 class="fw-700 text-white mb-1"><i class="fas fa-question-circle me-2"></i>Help & Support</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item active">Help</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container-fluid px-4 py-5">
    <div class="row g-4">
        <!-- FAQ Card -->
        <div class="col-md-6 col-lg-3">
            <div class="help-card card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="help-icon mb-3">
                        <i class="fas fa-comments fa-3x text-primary"></i>
                    </div>
                    <h5 class="fw-600 mb-2">Frequently Asked Questions</h5>
                    <p class="text-muted small mb-3">Find answers to common questions about ResumeAI</p>
                    <a asp-action="FAQ" class="btn btn-primary btn-sm">View FAQ</a>
                </div>
            </div>
        </div>

        <!-- Documentation Card -->
        <div class="col-md-6 col-lg-3">
            <div class="help-card card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="help-icon mb-3">
                        <i class="fas fa-book fa-3x text-info"></i>
                    </div>
                    <h5 class="fw-600 mb-2">Documentation</h5>
                    <p class="text-muted small mb-3">Complete technical documentation and API reference</p>
                    <a asp-action="Documentation" class="btn btn-info btn-sm">Read Docs</a>
                </div>
            </div>
        </div>

        <!-- User Guide Card -->
        <div class="col-md-6 col-lg-3">
            <div class="help-card card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="help-icon mb-3">
                        <i class="fas fa-graduation-cap fa-3x text-success"></i>
                    </div>
                    <h5 class="fw-600 mb-2">User Guide</h5>
                    <p class="text-muted small mb-3">Step-by-step guides for getting started</p>
                    <a asp-action="UserGuide" class="btn btn-success btn-sm">View Guide</a>
                </div>
            </div>
        </div>

        <!-- Support Card -->
        <div class="col-md-6 col-lg-3">
            <div class="help-card card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="help-icon mb-3">
                        <i class="fas fa-headset fa-3x text-warning"></i>
                    </div>
                    <h5 class="fw-600 mb-2">Contact Support</h5>
                    <p class="text-muted small mb-3">Get help from our support team</p>
                    <a asp-action="Support" class="btn btn-warning btn-sm">Get Support</a>
                </div>
            </div>
        </div>
    </div>
</div>
