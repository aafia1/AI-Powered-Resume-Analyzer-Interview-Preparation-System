@{
    ViewData["Title"] = "Frequently Asked Questions";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="container-fluid px-4">
        <h4 class="fw-700 text-white mb-1"><i class="fas fa-comments me-2"></i>Frequently Asked Questions</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item"><a asp-controller="Help" asp-action="Index">Help</a></li>
                <li class="breadcrumb-item active">FAQ</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container-fluid px-4 py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="accordion" id="faqAccordion">
                <!-- Q1 -->
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                            <i class="fas fa-caret-right me-2 text-primary"></i>What is ResumeAI?
                        </button>
                    </h2>
                    <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            ResumeAI is an AI-powered resume analyzer and interview preparation platform. It helps you optimize your resume, match it with job descriptions, and prepare for interviews with AI-generated questions.
                        </div>
                    </div>
                </div>

                <!-- Q2 -->
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                            <i class="fas fa-caret-right me-2 text-primary"></i>How do I upload my resume?
                        </button>
                    </h2>
                    <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            Navigate to "Upload Resume" from the dashboard. Click the upload area or drag and drop your PDF or DOCX file. The system will parse your resume and extract key information automatically.
                        </div>
                    </div>
                </div>

                <!-- Q3 -->
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                            <i class="fas fa-caret-right me-2 text-primary"></i>What file formats are supported?
                        </button>
                    </h2>
                    <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            We support PDF (.pdf) and Word documents (.docx). Maximum file size is 10MB. Ensure your document is properly formatted for accurate parsing.
                        </div>
                    </div>
                </div>

                <!-- Q4 -->
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                            <i class="fas fa-caret-right me-2 text-primary"></i>How does job matching work?
                        </button>
                    </h2>
                    <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            The job matching feature compares your resume skills with the job description requirements. It calculates a compatibility score and highlights matched and missing skills to help you understand your fit for the role.
                        </div>
                    </div>
                </div>

                <!-- Q5 -->
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq5">
                            <i class="fas fa-caret-right me-2 text-primary"></i>Can I download my analysis as a PDF?
                        </button>
                    </h2>
                    <div id="faq5" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            Yes! After analyzing your resume, you can generate and download a comprehensive PDF report containing your analysis results, suggestions, and recommendations.
                        </div>
                    </div>
                </div>

                <!-- Q6 -->
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq6">
                            <i class="fas fa-caret-right me-2 text-primary"></i>Is my resume data secure?
                        </button>
                    </h2>
                    <div id="faq6" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            Your data security is our top priority. All resumes are stored securely, encrypted, and only accessible by you. We never share your data with third parties.
                        </div>
                    </div>
                </div>

                <!-- Q7 -->
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq7">
                            <i class="fas fa-caret-right me-2 text-primary"></i>How are interview questions generated?
                        </button>
                    </h2>
                    <div id="faq7" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            Interview questions are generated based on the skills detected in your resume. Our AI system matches skills with common interview questions for different difficulty levels (Beginner, Intermediate, Advanced).
                        </div>
                    </div>
                </div>

                <!-- Q8 -->
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq8">
                            <i class="fas fa-caret-right me-2 text-primary"></i>Can I delete my resume?
                        </button>
                    </h2>
                    <div id="faq8" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            Yes, you can delete any of your uploaded resumes at any time from the History page. Deleted resumes cannot be recovered, so please make sure before deleting.
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mt-5 border-0 shadow-sm bg-light">
                <div class="card-body p-4">
                    <h6 class="fw-600 mb-2"><i class="fas fa-lightbulb me-2 text-warning"></i>Didn't find your answer?</h6>
                    <p class="text-muted mb-3">Contact our support team for additional help and personalized assistance.</p>
                    <a asp-controller="Help" asp-action="Support" class="btn btn-primary">Contact Support</a>
                </div>
            </div>
        </div>
    </div>
</div>
