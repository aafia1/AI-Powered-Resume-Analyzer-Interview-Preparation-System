@{
    ViewData["Title"] = "Contact Support";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="container-fluid px-4">
        <h4 class="fw-700 text-white mb-1"><i class="fas fa-headset me-2"></i>Contact Support</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item"><a asp-controller="Help" asp-action="Index">Help</a></li>
                <li class="breadcrumb-item active">Support</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container-fluid px-4 py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <!-- Support Options -->
            <div class="row g-4 mb-5">
                <div class="col-md-6">
                    <div class="support-card card h-100 border-0 shadow-sm">
                        <div class="card-body p-4 text-center">
                            <div class="mb-3">
                                <i class="fas fa-envelope fa-2x text-primary"></i>
                            </div>
                            <h6 class="fw-600 mb-2">Email Support</h6>
                            <p class="text-muted small mb-3">Send us an email and we'll respond within 24 hours</p>
                            <a href="mailto:aafiaazhar0@gmail.com" class="btn btn-primary btn-sm">aafiaazhar0@gmail.com</a>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="support-card card h-100 border-0 shadow-sm">
                        <div class="card-body p-4 text-center">
                            <div class="mb-3">
                                <i class="fas fa-comments fa-2x text-info"></i>
                            </div>
                            <h6 class="fw-600 mb-2">Live Chat</h6>
                            <p class="text-muted small mb-3">Chat with our support team in real-time</p>
                            <button class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#chatModal">Start Chat</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="card border-0 shadow-sm mb-5">
                <div class="card-body p-4">
                    <h6 class="fw-600 mb-3"><i class="fas fa-pencil-alt me-2 text-success"></i>Send us a Message</h6>
                    <form method="post" asp-action="SendMessage">
                        <div class="mb-3">
                            <label class="form-label">Subject</label>
                            <input type="text" name="subject" class="form-control" placeholder="e.g., Issue with resume upload" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Category</label>
                            <select name="category" class="form-select" required>
                                <option value="">Select a category</option>
                                <option value="Technical Issue">Technical Issue</option>
                                <option value="Feature Request">Feature Request</option>
                                <option value="Account Issue">Account Issue</option>
                                <option value="Billing">Billing</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Message</label>
                            <textarea name="message" class="form-control" rows="6" placeholder="Describe your issue or question in detail..." required></textarea>
                        </div>

                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-paper-plane me-2"></i>Send Message
                        </button>
                    </form>
                </div>
            </div>

            <!-- FAQ Reference -->
            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body p-4">
                    <h6 class="fw-600 mb-2"><i class="fas fa-question-circle me-2 text-primary"></i>Quick Links</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <a asp-controller="Help" asp-action="FAQ" class="text-decoration-none">
                                <i class="fas fa-chevron-right me-2 text-primary"></i>View FAQ
                            </a>
                        </div>
                        <div class="col-md-6">
                            <a asp-controller="Help" asp-action="UserGuide" class="text-decoration-none">
                                <i class="fas fa-chevron-right me-2 text-primary"></i>User Guide
                            </a>
                        </div>
                        <div class="col-md-12">
                            <a asp-controller="Help" asp-action="Documentation" class="text-decoration-none">
                                <i class="fas fa-chevron-right me-2 text-primary"></i>Documentation
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Chat Modal -->
<div class="modal fade" id="chatModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h6 class="modal-title fw-600"><i class="fas fa-comments me-2"></i>Live Chat Support</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info small" role="alert">
                    <i class="fas fa-info-circle me-2"></i>Our support team is typically available during business hours (9 AM - 5 PM EST, Monday - Friday).
                </div>
                <p class="text-muted small">For immediate assistance, please use the form above or send an email. We'll get back to you as soon as possible.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
                <a href="mailto:aafiaazhar0@gmail.com" class="btn btn-primary btn-sm">Send Email</a>
            </div>
        </div>
    </div>
</div>
