@{
    ViewData["Title"] = "Upload Resume";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="container-fluid px-4">
        <h4 class="fw-700 text-white mb-1"><i class="fas fa-upload me-2"></i>Upload Resume</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item active">Upload Resume</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container-fluid px-4 py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger alert-dismissible mb-4">
                    @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div><i class="fas fa-exclamation-circle me-1"></i>@e.ErrorMessage</div>
                    }
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="Upload" method="post" enctype="multipart/form-data" id="uploadForm">

                <!-- Upload Zone -->
                <div class="card mb-4">
                    <div class="card-body p-4">
                        <h6 class="fw-600 mb-3"><i class="fas fa-file-upload me-2 text-primary"></i>Select Resume File</h6>

                        <div class="upload-zone" id="uploadZone">
                            <i class="fas fa-cloud-upload-alt upload-icon"></i>
                            <h5 class="fw-600 mb-2">Drag & Drop your resume here</h5>
                            <p class="text-muted mb-3">or click to browse files</p>
                            <span class="badge bg-secondary-subtle text-secondary me-1">PDF</span>
                            <span class="badge bg-secondary-subtle text-secondary">DOCX</span>
                            <p class="text-muted small mt-2 mb-0">Maximum file size: 10 MB</p>
                        </div>

                        <input type="file" id="resumeFile" name="resumeFile" accept=".pdf,.docx" class="d-none" />

                        <!-- File Preview -->
                        <div id="filePreview" class="d-none mt-3">
                            <div class="d-flex align-items-center gap-3 p-3 rounded-xl" style="background:var(--primary-light);border:1px solid rgba(99,102,241,.2);">
                                <div style="width:48px;height:48px;border-radius:10px;background:var(--primary);display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.2rem;">
                                    <i class="fas fa-file-alt"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="fw-600 text-primary" id="previewName">filename.pdf</div>
                                    <div class="small text-muted"><span id="previewSize">0 KB</span> · Ready to upload</div>
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-danger" id="removeFile">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Optional Job Title -->
                <div class="card mb-4">
                    <div class="card-body p-4">
                        <h6 class="fw-600 mb-1"><i class="fas fa-briefcase me-2 text-primary"></i>Target Job Title <span class="badge bg-secondary-subtle text-secondary ms-1">Optional</span></h6>
                        <p class="text-muted small mb-3">Provide a job title to get more targeted analysis</p>
                        <input type="text" name="jobTitle" class="form-control" placeholder="e.g. Senior .NET Developer, Full Stack Engineer..." />
                    </div>
                </div>

                <!-- What happens next -->
                <div class="card mb-4" style="border:none;background:linear-gradient(135deg,rgba(99,102,241,.06),rgba(139,92,246,.06));">
                    <div class="card-body p-4">
                        <h6 class="fw-600 mb-3"><i class="fas fa-magic me-2 text-primary"></i>What happens after upload?</h6>
                        <div class="row g-3">
                            @{
                                var steps = new[] {
                                    ("fas fa-search", "Text Extraction", "We extract all text from your resume file"),
                                    ("fas fa-brain", "AI Parsing", "Skills, contact info, and sections are identified"),
                                    ("fas fa-chart-bar", "Score Calculation", "Resume score and ATS compatibility are computed"),
                                    ("fas fa-lightbulb", "Suggestions", "Personalized improvement tips are generated")
                                };
                            }
                            @foreach (var (icon, title, desc) in steps)
                            {
                                <div class="col-sm-6">
                                    <div class="d-flex gap-3">
                                        <div style="width:36px;height:36px;border-radius:8px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;color:var(--primary);flex-shrink:0;">
                                            <i class="@icon"></i>
                                        </div>
                                        <div>
                                            <div class="fw-600 small">@title</div>
                                            <div class="text-muted" style="font-size:.8rem;">@desc</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg py-3" id="submitBtn" disabled>
                        <span class="spinner-border spinner-border-sm me-2 d-none" id="spinner"></span>
                        <i class="fas fa-rocket me-2" id="submitIcon"></i>
                        <span id="submitText">Analyze My Resume</span>
                    </button>
                </div>
            </form>
        </div>

        <!-- Tips Sidebar -->
        <div class="col-lg-4 mt-4 mt-lg-0">
            <div class="card mb-3">
                <div class="card-body p-4">
                    <h6 class="fw-600 mb-3"><i class="fas fa-star me-2 text-warning"></i>Resume Tips</h6>
                    @{
                        var tips = new[] {
                            ("Use clear section headings like Experience, Education, Skills", "success"),
                            ("Include quantifiable achievements (increased sales by 30%)", "info"),
                            ("Keep your resume to 1-2 pages maximum", "warning"),
                            ("Use industry keywords from job descriptions", "primary"),
                            ("Include your GitHub, LinkedIn, or portfolio link", "secondary")
                        };
                    }
                    @foreach (var (tip, color) in tips)
                    {
                        <div class="d-flex gap-2 mb-2">
                            <i class="fas fa-check-circle text-@color mt-1 flex-shrink-0"></i>
                            <span class="small text-muted">@tip</span>
                        </div>
                    }
                </div>
            </div>

            <div class="card">
                <div class="card-body p-4">
                    <h6 class="fw-600 mb-3"><i class="fas fa-shield-alt me-2 text-success"></i>File Security</h6>
                    <p class="text-muted small mb-2">Your resume is stored securely and only accessible by you.</p>
                    <div class="d-flex gap-2 mb-2">
                        <i class="fas fa-lock text-success mt-1 flex-shrink-0"></i>
                        <span class="small text-muted">Encrypted file storage</span>
                    </div>
                    <div class="d-flex gap-2 mb-2">
                        <i class="fas fa-user-shield text-success mt-1 flex-shrink-0"></i>
                        <span class="small text-muted">Private to your account</span>
                    </div>
                    <div class="d-flex gap-2">
                        <i class="fas fa-trash-alt text-success mt-1 flex-shrink-0"></i>
                        <span class="small text-muted">Delete anytime</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('removeFile')?.addEventListener('click', () => {
    document.getElementById('resumeFile').value = '';
    document.getElementById('filePreview').classList.add('d-none');
    document.getElementById('submitBtn').disabled = true;
});

document.getElementById('resumeFile').addEventListener('change', () => {
    document.getElementById('submitBtn').disabled = false;
});

document.getElementById('uploadForm').addEventListener('submit', () => {
    const btn = document.getElementById('submitBtn');
    const spinner = document.getElementById('spinner');
    const icon = document.getElementById('submitIcon');
    const text = document.getElementById('submitText');
    btn.disabled = true;
    spinner.classList.remove('d-none');
    icon.classList.add('d-none');
    text.textContent = 'Analyzing...';
});
</script>
}
