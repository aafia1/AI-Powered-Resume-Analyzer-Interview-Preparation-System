@model ResumeAnalyzer.ViewModels.JobMatchViewModel
@{
    ViewData["Title"] = "Job Description Matching";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="container-fluid px-4">
        <h4 class="fw-700 text-white mb-1"><i class="fas fa-briefcase me-2"></i>Job Description Matching</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item active">Job Match</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container-fluid px-4 py-4">
    <div class="row g-4">

        <!-- Input Form -->
        <div class="col-lg-5">
            <div class="card">
                <div class="card-body p-4">
                    <h6 class="fw-600 mb-1"><i class="fas fa-paste me-2 text-primary"></i>Job Description</h6>
                    <p class="text-muted small mb-4">Select your resume and paste a job description to see your compatibility score.</p>

                    <form asp-action="JobMatch" method="post">
                        <!-- Select Resume -->
                        <div class="mb-3">
                            <label class="form-label">Select Resume</label>
                            <select name="resumeId" class="form-select" required>
                                <option value="">-- Choose a resume --</option>
                                @if (ViewBag.Resumes != null)
                                {
                                    foreach (var r in (dynamic)ViewBag.Resumes)
                                    {
                                        var isSelected = (int)r.Id == (int)(ViewBag.SelectedResumeId ?? 0);
                                        <option value="@r.Id" selected="@(isSelected ? "selected" : null)">@r.FileName</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Job Title</label>
                            <input type="text" name="jobTitle" class="form-control" value="@Model.JobTitle"
                                   placeholder="e.g. Senior Software Engineer" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Job Description</label>
                            <textarea name="jobDescription" class="form-control" rows="12"
                                      placeholder="Paste the full job description here...
                                      
We are looking for a Senior .NET Developer with experience in:
• ASP.NET Core, C#, SQL Server
• React / Angular frontend
• Docker & Kubernetes
• REST API design
..." required>@Model.JobDescription</textarea>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2">
                            <i class="fas fa-search me-2"></i>Analyze Compatibility
                        </button>
                    </form>
                </div>
            </div>

            @if (ViewBag.Resumes != null)
            {
                var resumeList = (dynamic)ViewBag.Resumes;
                bool hasResumes = false;
                foreach (var _ in resumeList) { hasResumes = true; break; }
                if (!hasResumes)
                {
                    <div class="card mt-3" style="border:2px dashed var(--border);">
                        <div class="card-body text-center p-4">
                            <i class="fas fa-file-upload fa-2x text-muted mb-3 opacity-50"></i>
                            <p class="text-muted small mb-2">No resumes uploaded yet</p>
                            <a asp-controller="Resume" asp-action="Upload" class="btn btn-primary btn-sm">Upload Resume</a>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Results -->
        <div class="col-lg-7">
            @if (!Model.IsAnalyzed)
            {
                <div class="card h-100" style="min-height:400px;">
                    <div class="card-body d-flex flex-column align-items-center justify-content-center text-center p-5">
                        <div style="width:100px;height:100px;border-radius:50%;background:var(--primary-light);display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;font-size:2.5rem;color:var(--primary);">
                            <i class="fas fa-briefcase"></i>
                        </div>
                        <h5 class="fw-600 mb-2">Ready to Match</h5>
                        <p class="text-muted mb-0" style="max-width:380px;">
                            Select a resume, paste a job description, and click Analyze to see how well you match the role.
                        </p>
                    </div>
                </div>
            }
            else
            {
                <!-- Compatibility Score -->
                <div class="card mb-3">
                    <div class="card-body p-4">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <div class="score-ring" data-score="@Model.CompatibilityScore" style="width:110px;height:110px;"></div>
                            </div>
                            <div class="col">
                                <h5 class="fw-700 mb-1">@Model.JobTitle</h5>
                                <p class="text-muted small mb-2">Compatibility with job description</p>
                                @if (Model.CompatibilityScore >= 70)
                                {
                                    <span class="badge bg-success-subtle text-success px-3 py-2">
                                        <i class="fas fa-thumbs-up me-1"></i>Strong Match — Apply with confidence!
                                    </span>
                                }
                                else if (Model.CompatibilityScore >= 40)
                                {
                                    <span class="badge bg-warning-subtle text-warning px-3 py-2">
                                        <i class="fas fa-exclamation-circle me-1"></i>Moderate Match — Close some skill gaps first
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger px-3 py-2">
                                        <i class="fas fa-times-circle me-1"></i>Weak Match — Significant skills missing
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Matched / Missing Skills -->
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-body p-4">
                                <h6 class="fw-600 mb-3 text-success">
                                    <i class="fas fa-check-circle me-2"></i>Matched Skills
                                    <span class="badge bg-success ms-1">@Model.MatchedSkills.Count</span>
                                </h6>
                                @if (Model.MatchedSkills.Any())
                                {
                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var s in Model.MatchedSkills)
                                        {
                                            <span class="skill-badge matched">
                                                <i class="fas fa-check"></i> @s
                                            </span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted small mb-0">No matching skills found.</p>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-body p-4">
                                <h6 class="fw-600 mb-3 text-danger">
                                    <i class="fas fa-times-circle me-2"></i>Missing Skills
                                    <span class="badge bg-danger ms-1">@Model.MissingSkills.Count</span>
                                </h6>
                                @if (Model.MissingSkills.Any())
                                {
                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var s in Model.MissingSkills)
                                        {
                                            <span class="skill-badge missing">
                                                <i class="fas fa-times"></i> @s
                                            </span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-success small mb-0"><i class="fas fa-star me-1"></i>You have all required skills!</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Match Bar Chart -->
                <div class="card mb-3">
                    <div class="card-body p-4">
                        <h6 class="fw-600 mb-3"><i class="fas fa-chart-bar me-2 text-primary"></i>Skills Breakdown</h6>
                        <canvas id="matchChart" height="80"></canvas>
                    </div>
                </div>

                <!-- Recommendations -->
                @if (Model.Recommendations.Any())
                {
                    <div class="card">
                        <div class="card-body p-4">
                            <h6 class="fw-600 mb-3"><i class="fas fa-lightbulb me-2 text-warning"></i>Recommendations</h6>
                            <div class="d-flex flex-column gap-3">
                                @foreach (var r in Model.Recommendations)
                                {
                                    <div class="suggestion-card priority-@r.Priority.ToLower()">
                                        <div class="d-flex gap-3">
                                            <i class="@r.Icon text-@r.BadgeColor mt-1 flex-shrink-0"></i>
                                            <div>
                                                <div class="fw-600 small mb-1">@r.Title</div>
                                                <p class="text-muted mb-0" style="font-size:.82rem;">@r.Description</p>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
@if (Model.IsAnalyzed)
{
    <script>
    new Chart(document.getElementById('matchChart'), {
        type: 'bar',
        data: {
            labels: ['Matched Skills', 'Missing Skills', 'Compatibility %'],
            datasets: [{
                data: [@Model.MatchedSkills.Count, @Model.MissingSkills.Count, @Model.CompatibilityScore],
                backgroundColor: ['rgba(16,185,129,0.8)', 'rgba(239,68,68,0.8)', 'rgba(99,102,241,0.8)'],
                borderRadius: 8,
                borderSkipped: false
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' } },
                x: { grid: { display: false } }
            }
        }
    });
    </script>
}
}
